DATABASE_URL=postgres://tripatlas:tripatlas@localhost:5432/tripatlas
TESLAMATE_DATABASE_URL=postgres://teslamate:teslamate@localhost:5433/teslamate
APP_TIMEZONE=Europe/Zurich
SYNC_INTERVAL_SECONDS=60
# INITIAL_ADMIN_PASSWORD=

# --- Produktion (docker-compose.yml) -----------------------------------
# Passwort für die tripatlas-Postgres im Compose-Stack. Pflichtfeld, kein
# Default — Compose bricht ohne gesetzten Wert ab.
POSTGRES_PASSWORD=

# Port, unter dem die Web-App auf dem Host erreichbar ist (z. B. hinter
# Tailscale serve). Intern läuft der Container immer auf 3000.
WEB_PORT=3000

# In Produktion: read-only-Rolle auf der bestehenden TeslaMate-DB verwenden,
# siehe README "Deployment" für das CREATE ROLE-Statement. Host entweder
# LAN/Tailscale-Adresse oder, falls TeslaMate im selben Compose-Netz läuft,
# der Service-Name (siehe Kommentare in docker-compose.yml).
# TESLAMATE_DATABASE_URL=postgres://tripatlas_ro:...@teslamate-host:5432/teslamate
